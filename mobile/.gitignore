node_modules/
.expo/
dist/

# CNG (Continuous Native Generation): expo prebuild regenera estos
# directorios en cada build de EAS. No los commiteamos.
android/
ios/

# The root .gitignore excludes *.db, but mobile bundles the initial
# pre-populated snapshot as an asset — un-ignore it here.
!assets/rinnegan_initial.db
npm-debug.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/
.DS_Store
